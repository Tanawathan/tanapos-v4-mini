# TanaPOS V4-Mini 環境配置
# 複製此檔案為 .env 並填入實際值

# Supabase 配置 (請從您的 Supabase 控制台取得)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# 應用配置
VITE_APP_NAME="TanaPOS V4-Mini"
VITE_APP_VERSION="1.0.0"

# 開發模式配置
VITE_DEV_MODE=true
VITE_DEBUG_LOGS=true

# POS 系統配置
VITE_DEFAULT_TAX_RATE=0.07
VITE_CURRENCY_SYMBOL="NT$"
VITE_CURRENCY_CODE="TWD"

# 功能開關
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_SOUND_NOTIFICATIONS=true
VITE_ENABLE_VIBRATION=true

# KDS 配置
VITE_KDS_AUTO_REFRESH_INTERVAL=5000
VITE_KDS_COMPLETED_ORDER_TIMEOUT=300000

# 餐廳資訊
VITE_RESTAURANT_NAME="TanaPOS Demo"
VITE_RESTAURANT_ADDRESS="台北市信義區信義路五段7號"
VITE_RESTAURANT_PHONE="02-1234-5678"
