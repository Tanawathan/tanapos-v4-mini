# 舊資料庫設定 (用於資料轉移)
# 請填入您舊 Supabase 專案的連接資訊

# 舊 Supabase 專案 URL
OLD_SUPABASE_URL=https://your-old-project.supabase.co

# 舊 Supabase 專案 Service Role Key
OLD_SUPABASE_SERVICE_KEY=your-old-service-role-key

# 範例:
# OLD_SUPABASE_URL=https://abcdefghijklmnop.supabase.co
# OLD_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
